# ops/terraform.tfvars.example
#
# 사용법:
#   cp terraform.tfvars.example terraform.tfvars
#   terraform.tfvars 에서 실제 값으로 수정 후 apply
#
# ⚠️ terraform.tfvars는 .gitignore에 포함 — 절대 커밋하지 마세요.

# IAM 리소스 이름 prefix (소문자, 숫자, 하이픈만 허용)
app_name = "dev-app"

# AWS 리전 — 서울 리전 기본값
aws_region = "ap-northeast-2"

# GitHub OIDC 신뢰 관계 설정
# 이 값들은 코드가 있는 레포를 기준으로 작성
github_org  = "your-github-org"   # GitHub 조직명 또는 개인 계정 사용자명
github_repo = "your-github-repo"  # 코드 레포 이름 (이 관리 레포 아님)
