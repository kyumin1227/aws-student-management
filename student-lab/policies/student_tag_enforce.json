{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "DenyRunInstancesWithoutOwnerTag",
      "Effect": "Deny",
      "Action": "ec2:RunInstances",
      "Resource": "arn:aws:ec2:*:*:instance/*",
      "Condition": {
        "StringNotEquals": {
          "aws:RequestTag/Owner": "${aws:PrincipalTag/userName}"
        }
      }
    },
    {
      "Sid": "DenyCreateResourcesWithoutOwnerTag",
      "Effect": "Deny",
      "Action": [
        "ec2:CreateVolume",
        "ec2:CreateSnapshot",
        "ec2:AllocateAddress",
        "rds:CreateDBInstance",
        "rds:CreateDBCluster"
      ],
      "Resource": "*",
      "Condition": {
        "StringNotEquals": {
          "aws:RequestTag/Owner": "${aws:PrincipalTag/userName}"
        }
      }
    },
    {
      "Sid": "DenyDeleteOwnerTag",
      "Effect": "Deny",
      "Action": "ec2:DeleteTags",
      "Resource": "*",
      "Condition": {
        "ForAnyValue:StringEquals": {
          "aws:TagKeys": ["Owner"]
        }
      }
    },
    {
      "Sid": "DenyModifyOwnerTagAfterCreate",
      "Effect": "Deny",
      "Action": "ec2:CreateTags",
      "Resource": "*",
      "Condition": {
        "ForAnyValue:StringEquals": {
          "aws:TagKeys": ["Owner"]
        },
        "StringNotEquals": {
          "ec2:CreateAction": ["RunInstances", "AllocateAddress"]
        }
      }
    },
    {
      "Sid": "DenyOwnerTagModificationViaTaggingAPI",
      "Effect": "Deny",
      "Action": ["tag:TagResources", "tag:UntagResources"],
      "Resource": "*",
      "Condition": {
        "ForAnyValue:StringEquals": {
          "aws:TagKeys": ["Owner"]
        }
      }
    },
    {
      "Sid": "DenyRDSOwnerTagModification",
      "Effect": "Deny",
      "Action": ["rds:AddTagsToResource", "rds:RemoveTagsFromResource"],
      "Resource": "*",
      "Condition": {
        "ForAnyValue:StringEquals": {
          "aws:TagKeys": ["Owner"]
        }
      }
    },
    {
      "Sid": "DenyS3TagModification",
      "Effect": "Deny",
      "Action": ["s3:DeleteBucketTagging", "s3:PutBucketTagging", "s3:TagResource", "s3:UntagResource"],
      "Resource": "*"
    },
    {
      "Sid": "DenyOtherRegions",
      "Effect": "Deny",
      "NotAction": ["iam:*", "sts:*", "route53:*", "budgets:*", "account:*", "support:*", "aws-portal:*", "ce:*"],
      "Resource": "*",
      "Condition": {
        "StringNotEquals": {
          "aws:RequestedRegion": "ap-northeast-2"
        }
      }
    },
    {
      "Sid": "DenyNatGateway",
      "Effect": "Deny",
      "Action": ["ec2:CreateNatGateway"],
      "Resource": "*"
    },
    {
      "Sid": "DenyExpensiveServices",
      "Effect": "Deny",
      "Action": [
        "ec2:RequestSpotInstances",
        "ec2:RequestSpotFleet",
        "ec2:CreateSpotDatafeedSubscription",
        "elasticache:CreateCacheCluster",
        "elasticache:CreateReplicationGroup",
        "redshift:CreateCluster",
        "redshift:RestoreFromClusterSnapshot",
        "eks:CreateCluster",
        "emr:RunJobFlow"
      ],
      "Resource": "*"
    },
    {
      "Sid": "DenyExpensiveInstanceTypes",
      "Effect": "Deny",
      "Action": "ec2:RunInstances",
      "Resource": "arn:aws:ec2:*:*:instance/*",
      "Condition": {
        "StringLike": {
          "ec2:InstanceType": [
            "p2.*",
            "p3.*",
            "p4d.*",
            "p5.*",
            "g3.*",
            "g4dn.*",
            "g4ad.*",
            "g5.*",
            "g5g.*",
            "x1.*",
            "x2.*",
            "u-*",
            "trn1.*",
            "inf1.*",
            "inf2.*"
          ]
        }
      }
    },
    {
      "Sid": "DenyActionsOnOthersResources",
      "Effect": "Deny",
      "Action": [
        "ec2:StartInstances",
        "ec2:StopInstances",
        "ec2:TerminateInstances",
        "ec2:RebootInstances",
        "ec2:ModifyInstanceAttribute",
        "ec2:AttachVolume",
        "ec2:DetachVolume",
        "ec2:DeleteVolume",
        "rds:Delete*",
        "rds:Modify*",
        "rds:Reboot*",
        "rds:Stop*",
        "s3:DeleteBucket",
        "s3:DeleteObject",
        "s3:PutObject"
      ],
      "Resource": "*",
      "Condition": {
        "StringNotEquals": {
          "aws:ResourceTag/Owner": "${aws:PrincipalTag/userName}"
        },
        "Null": {
          "aws:ResourceTag/Owner": "false"
        }
      }
    },
    {
      "Sid": "DenyS3ActionsOnOthersBuckets",
      "Effect": "Deny",
      "Action": ["s3:PutObject", "s3:DeleteObject", "s3:GetObject"],
      "Resource": "arn:aws:s3:::*/*",
      "Condition": {
        "StringNotEquals": {
          "aws:ResourceTag/Owner": "${aws:PrincipalTag/userName}"
        }
      }
    },
    {
      "Sid": "EnforceOwnerTagOnCreate",
      "Effect": "Deny",
      "Action": "s3:CreateBucket",
      "Resource": "arn:aws:s3:::*",
      "Condition": {
        "StringNotEquals": {
          "aws:RequestTag/Owner": "${aws:PrincipalTag/userName}"
        }
      }
    },
    {
      "Sid": "AllowCreateWithTag",
      "Effect": "Allow",
      "Action": "s3:CreateBucket",
      "Resource": "arn:aws:s3:::*"
    },
    {
      "Sid": "DenyBillingAndCostAnalysis",
      "Effect": "Deny",
      "Action": ["aws-portal:*", "billing:*", "cur:*", "ce:*"],
      "Resource": "*"
    }
  ]
}
